{
  "name": "@pi-stef/cursor",
  "version": "1.0.0",
  "description": "Cursor AI editor as a native Pi stream provider — @cursor/sdk local-agent mode, API-key auth",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sfiorini/pi-stef.git",
    "directory": "packages/cursor"
  },
  "homepage": "https://sfiorini.github.io/pi-stef/packages/cursor.html",
  "files": [
    "src/",
    "extensions/",
    "scripts/",
    "docs/"
  ],
  "exports": {
